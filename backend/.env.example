PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d
NODE_ENV=development

# ---- Database ----
# Leave empty for zero-setup local dev (JSON files in backend/data).
# For Neon: create a project at https://neon.tech and paste the connection string:
# DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ---- Admin ----
# Log in with this phone number (OTP flow) to access /admin
ADMIN_PHONE=9999999999
ADMIN_EMAIL=

# ---- OTP ----
OTP_EXPIRY_MINUTES=5

# ---- SMS (optional — logs to console when unset) ----
# MSG91 (Flow API): requires a DLT-approved template with ONE variable, e.g.
#   "{{VAR1}} is your Yamuna Organics OTP. Valid 5 minutes."
# Create it at https://control.msg91.com, then paste its id below.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_VAR_NAME=VAR1
SMS_SENDER_ID=YAMUNA
# ...or Twilio (sends free-form text, no template needed):
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---- Email (optional — logs to console when unset) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Yamuna Organics <no-reply@yamunaorganics.com>
CONTACT_NOTIFY_EMAIL=owner@yamunaorganics.com

# ---- Uploads ----
# Override where uploaded banner videos are stored (e.g. a Render disk mount)
UPLOADS_DIR=
