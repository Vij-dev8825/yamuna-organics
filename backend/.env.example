PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d
NODE_ENV=development

# Used to build absolute image URLs for notification emails/push (relative
# paths like /api/media/xyz don't work in email clients or push payloads)
SITE_URL=https://yamuna-organics.onrender.com

# ---- Database ----
# Leave empty for zero-setup local dev (JSON files in backend/data).
# For Neon: create a project at https://neon.tech and paste the connection string:
# DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ---- Admin ----
# Log in with this phone number (OTP flow) to access /admin
ADMIN_PHONE=9999999999
ADMIN_EMAIL=westerngodsorganic@gmail.com

# ---- OTP ----
OTP_EXPIRY_MINUTES=5
# Set true to show the real OTP on-screen in production too (e.g. while SMS
# delivery isn't set up yet). Turn back off once real SMS delivery works —
# this exposes the login code in the API response, only enable temporarily.
SHOW_OTP_ONSCREEN=false

# ---- SMS (optional — logs to console when unset) ----
# Fast2SMS: free-credit signup at https://www.fast2sms.com (Indian numbers).
# Dashboard → API → paste the "Authorization" key below. Their OTP route
# needs no DLT template and is used for login OTPs; the Quick SMS route
# (admin broadcast SMS) is best-effort — some carriers require a
# DLT-registered template for non-OTP text, in which case it falls back to
# Twilio/console below.
FAST2SMS_API_KEY=
# ...or MSG91 OTP API: used only for login OTPs (routes/auth.js). Create an
# OTP-category template at MSG91 dashboard → OTP → SendOTP → Templates,
# shaped like "##OTP## is your Western Gods Organics OTP. Valid 5 minutes."
# Real delivery in India additionally requires DLT registration of your
# business + Sender ID + this template (separate from MSG91 itself).
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
SMS_SENDER_ID=YAMUNA
# ...or Twilio (sends free-form text, no template needed — used for OTPs
# AND admin broadcast SMS when set):
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---- Payments (optional — "Pay Online" is hidden/unusable until set) ----
# Razorpay: get Key ID + Key Secret from https://dashboard.razorpay.com
# → Settings → API Keys. Test-mode keys work immediately (no KYC needed);
# switching to live keys for real settlement requires Razorpay KYC.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Email (optional — logs to console when unset) ----
# Gmail SMTP (free): use your Gmail address as SMTP_USER, and a 16-character
# App Password (not your normal Gmail password) as SMTP_PASS — generate one
# at https://myaccount.google.com/apppasswords (requires 2-Step Verification
# to be turned on for the account first).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Western Gods Organics <westerngodsorganic@gmail.com>
CONTACT_NOTIFY_EMAIL=westerngodsorganic@gmail.com

# ---- Uploads ----
# Override where uploaded banner videos are stored (e.g. a Render disk mount)
UPLOADS_DIR=

# ---- Image/video storage (optional — falls back to local disk when unset) ----
# On Render's free plan, local disk is wiped on every redeploy, so admin
# uploads (product/category photos, banners) disappear. Set these to store
# uploads on Cloudinary instead, which survives redeploys.
# Sign up free at https://cloudinary.com → Dashboard → copy these 3 values.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Web Push (browser/OS notifications) ----
# Self-generated key pair, no external account needed. Generate your own with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:westerngodsorganic@gmail.com
