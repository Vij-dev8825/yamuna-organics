PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d
NODE_ENV=development

# ---- Database ----
# Leave empty for zero-setup local dev (JSON files in backend/data).
# For Neon: create a project at https://neon.tech and paste the connection string:
# DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ---- Admin ----
# Log in with this phone number (OTP flow) to access /admin
ADMIN_PHONE=9999999999
ADMIN_EMAIL=

# ---- OTP ----
OTP_EXPIRY_MINUTES=5
# Set true to show the real OTP on-screen in production too (e.g. while SMS
# delivery isn't set up yet). Turn back off once real SMS delivery works —
# this exposes the login code in the API response, only enable temporarily.
SHOW_OTP_ONSCREEN=false

# ---- SMS (optional — logs to console when unset) ----
# MSG91 OTP API: used only for login OTPs (routes/auth.js). Create an
# OTP-category template at MSG91 dashboard → OTP → SendOTP → Templates,
# shaped like "##OTP## is your Yamuna Organics OTP. Valid 5 minutes."
# Real delivery in India additionally requires DLT registration of your
# business + Sender ID + this template (separate from MSG91 itself).
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
SMS_SENDER_ID=YAMUNA
# ...or Twilio (sends free-form text, no template needed — used for OTPs
# AND admin broadcast SMS when set):
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---- Payments (optional — "Pay Online" is hidden/unusable until set) ----
# Razorpay: get Key ID + Key Secret from https://dashboard.razorpay.com
# → Settings → API Keys. Test-mode keys work immediately (no KYC needed);
# switching to live keys for real settlement requires Razorpay KYC.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Email (optional — logs to console when unset) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Yamuna Organics <no-reply@yamunaorganics.com>
CONTACT_NOTIFY_EMAIL=owner@yamunaorganics.com

# ---- Uploads ----
# Override where uploaded banner videos are stored (e.g. a Render disk mount)
UPLOADS_DIR=
